{
  "manifest_version": 3,
  "name": "MEXC Scalp Panel",
  "version": "1.0",
  "description": "Floating MEXC Futures order panel injected into TradingView",
  "permissions": ["storage"],
  "host_permissions": [
    "https://mexc-webhook-production.up.railway.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.tradingview.com/*",
        "https://tradingview.com/*"
      ],
      "js": ["content.js", "market-cockpit.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
