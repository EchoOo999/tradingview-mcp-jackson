MEXC_API_KEY=your_mexc_api_key_here
MEXC_SECRET=your_mexc_secret_here
PORT=3000
# Optional: if set, TradingView alert body must include "secret": "..." matching this value
WEBHOOK_SECRET=

# ── EchoOo-SAE forwarding ────────────────────────────────────────────────────
# When SAE_FORWARDING_ENABLED=true, scanner SFP/LJ detections POST to /ta-events
# with header X-SAE-Token. Default false — flip to true on Railway only after the
# token is set. Independent of Telegram ALERTS_ENABLED in scanner.js.
SAE_FORWARDING_ENABLED=false
SAE_INGEST_TOKEN=your_token_here
SAE_ENDPOINT=https://botbridge-production.up.railway.app/ta-events
